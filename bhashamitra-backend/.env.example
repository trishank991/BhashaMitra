# ===========================================
# BhashaMitra Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DJANGO SETTINGS
# ===========================================
# Environment: dev or prod
DJANGO_ENV=dev

# Secret key (generate a new one for production!)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production

# Debug mode (never True in production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# For development, you can use SQLite by setting USE_SQLITE=true
USE_SQLITE=true

# PostgreSQL settings (used when USE_SQLITE=false or in production)
DB_NAME=bhashamitra_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ===========================================
# CORS (Frontend URL)
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===========================================
# HUGGING FACE TTS (AI4Bharat Indic Parler-TTS)
# ===========================================
# High-quality TTS for Indian languages using AI4Bharat model
#
# HOW TO GET API TOKEN:
# =====================
# 1. Create account: https://huggingface.co/join
# 2. Go to Settings > Access Tokens: https://huggingface.co/settings/tokens
# 3. Create a new token (read access is sufficient)
# 4. Copy your token below
#
# RECOMMENDED: PRO Account ($9/month)
# ===================================
# - 10x more requests than free tier
# - No cold starts (faster response)
# - Priority queue access
# - Get PRO: https://huggingface.co/subscribe/pro
#
# SPACE INFO:
# ===========
# Default Space: parler-tts/parler_tts (English TTS)
# Alternative: ai4bharat/indic-parler-tts (Indian languages - when available)
# Space URL: https://huggingface.co/spaces/parler-tts/parler_tts
#
# SUPPORTED LANGUAGES:
# ====================
# parler-tts/parler_tts: English (with various accents)
# ai4bharat/indic-parler-tts: Hindi, Tamil, Telugu, Gujarati, Punjabi, Malayalam
#
# VOICE STYLES:
# =============
# - storyteller: Warm, engaging (best for stories)
# - calm: Soft, soothing (good for bedtime)
# - enthusiastic: Energetic (for games/activities)
#
# COST OPTIMIZATION:
# ==================
# With aggressive caching, expect ~$9/month total:
# - PRO subscription: $9/month
# - API calls: Near zero with caching
# - Cache strategy: Redis (24h) + S3/R2 (permanent)
#
HUGGINGFACE_API_TOKEN=hf_your_token_here
HUGGINGFACE_ACCOUNT_TYPE=free

# TTS Space Configuration
TTS_SPACE_ID=parler-tts/parler_tts
TTS_DEFAULT_VOICE_STYLE=storyteller
TTS_CACHE_TTL_SECONDS=86400

# ===========================================
# REDIS (Optional - for caching)
# ===========================================
# Used in production for caching and sessions
# Example: redis://localhost:6379/0
REDIS_URL=

# ===========================================
# FILE STORAGE (Production Only)
# ===========================================
# Set to true to use S3-compatible storage (Cloudflare R2, AWS S3, etc.)
USE_S3_STORAGE=false

# Cloudflare R2 settings
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bhashamitra-media
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=cdn.bhashamitra.co.nz

# OR AWS S3 settings (alternative to R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# ===========================================
# EMAIL (Production Only)
# ===========================================
# Using Resend (recommended)
RESEND_API_KEY=

# OR using SMTP
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@bhashamitra.co.nz

# ===========================================
# ERROR TRACKING (Production Only)
# ===========================================
# Sentry DSN for error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ===========================================
# GOOGLE OAUTH (Optional - for social login)
# ===========================================
# HOW TO GET CREDENTIALS:
# =======================
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a new project or select existing one
# 3. Enable "Google Sign-In" API
# 4. Go to Credentials > Create Credentials > OAuth Client ID
# 5. Choose "Web Application"
# 6. Add authorized origins: http://localhost:3000, https://yourdomain.com
# 7. Add authorized redirect URIs if needed
# 8. Copy Client ID below (backend validates tokens, no secret needed)
#
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ===========================================
# FRONTEND URL (for email links)
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# STRIPE PAYMENTS (MVP - Standard Tier Only)
# ===========================================
# HOW TO GET API KEYS:
# 1. Create account: https://dashboard.stripe.com/register
# 2. Go to Developers > API keys: https://dashboard.stripe.com/apikeys
# 3. Use test keys for development, live keys for production
#
# PRICE IDS:
# 1. Go to Products: https://dashboard.stripe.com/products
# 2. Create Standard product with monthly/yearly prices
# 3. Copy price IDs (starts with price_)
#
# WEBHOOK (Production Only):
# 1. Go to Webhooks: https://dashboard.stripe.com/webhooks
# 2. Add endpoint: https://yourdomain.com/api/v1/payments/webhooks/stripe/
# 3. Select events: checkout.session.completed, customer.subscription.*, invoice.*
#
# ===========================================

# Stripe API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Standard Tier Price IDs (Required for MVP)
STRIPE_PRICE_STANDARD_MONTHLY=price_standard_monthly_id
STRIPE_PRICE_STANDARD_YEARLY=price_standard_yearly_id

# Premium Tier Price IDs (Optional - Enable when live classes ready)
# STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly_id
# STRIPE_PRICE_PREMIUM_YEARLY=price_premium_yearly_id
# ENABLE_PREMIUM_TIER=false

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# PostHog for analytics (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
